# Copie para .env.development (dev) ou .env.prod (servidor) e preencha

# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/watchlist_development

# Redis
REDIS_URL=redis://redis:6379/0

# Rails
SECRET_KEY_BASE=troque_por_output_de_rails_secret
RAILS_ENV=development
RAILS_MAX_THREADS=5
RAILS_LOG_LEVEL=info

# APIs externas
# TVMaze (séries) e MediaWiki/Wikipedia (plot p/ IA) não exigem chave.
OMDB_API_KEY=          # filmes — https://www.omdbapi.com (free tier 1000 req/dia)
ANTHROPIC_API_KEY=     # geração dos resumos IA

# E-mail
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAILER_FROM=noreply@watchlist.local

# JWT (Devise JWT)
DEVISE_JWT_SECRET_KEY=troque_por_string_aleatoria_longa
